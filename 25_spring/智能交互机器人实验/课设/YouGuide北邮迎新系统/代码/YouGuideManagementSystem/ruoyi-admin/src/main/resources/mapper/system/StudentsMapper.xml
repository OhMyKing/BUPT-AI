<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.StudentsMapper">
    
    <resultMap type="Students" id="StudentsResult">
        <result property="studentId"    column="student_id"    />
        <result property="studentNum"    column="student_num"    />
        <result property="name"    column="name"    />
        <result property="gender"    column="gender"    />
        <result property="college"    column="college"    />
        <result property="major"    column="major"    />
        <result property="dormitoryId"    column="dormitory_id"    />
        <result property="dormitoryNo"    column="dormitory_no"    />
        <result property="phone"    column="phone"    />
        <result property="wechatEnterpriseId"    column="wechat_enterprise_id"    />
        <result property="flowPositionId"    column="flow_position_id"    />
        <result property="currentLatitude"    column="current_latitude"    />
        <result property="currentLongitude"    column="current_longitude"    />
    </resultMap>

    <sql id="selectStudentsVo">
        select student_id, student_num, name, gender, college, major, dormitory_id, dormitory_no, phone, wechat_enterprise_id, flow_position_id, current_latitude, current_longitude from students
    </sql>

    <select id="selectStudentsList" parameterType="Students" resultMap="StudentsResult">
        <include refid="selectStudentsVo"/>
        <where>  
            <if test="studentNum != null "> and student_num = #{studentNum}</if>
            <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
            <if test="gender != null  and gender != ''"> and gender = #{gender}</if>
            <if test="college != null  and college != ''"> and college = #{college}</if>
            <if test="major != null  and major != ''"> and major = #{major}</if>
            <if test="dormitoryId != null "> and dormitory_id = #{dormitoryId}</if>
            <if test="dormitoryNo != null  and dormitoryNo != ''"> and dormitory_no = #{dormitoryNo}</if>
            <if test="phone != null  and phone != ''"> and phone = #{phone}</if>
            <if test="wechatEnterpriseId != null  and wechatEnterpriseId != ''"> and wechat_enterprise_id = #{wechatEnterpriseId}</if>
            <if test="flowPositionId != null "> and flow_position_id = #{flowPositionId}</if>
            <if test="currentLatitude != null "> and current_latitude = #{currentLatitude}</if>
            <if test="currentLongitude != null "> and current_longitude = #{currentLongitude}</if>
        </where>
    </select>
    
    <select id="selectStudentsByStudentId" parameterType="Long" resultMap="StudentsResult">
        <include refid="selectStudentsVo"/>
        where student_id = #{studentId}
    </select>

    <insert id="insertStudents" parameterType="Students">
        insert into students
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="studentId != null">student_id,</if>
            <if test="studentNum != null">student_num,</if>
            <if test="name != null and name != ''">name,</if>
            <if test="gender != null and gender != ''">gender,</if>
            <if test="college != null and college != ''">college,</if>
            <if test="major != null and major != ''">major,</if>
            <if test="dormitoryId != null">dormitory_id,</if>
            <if test="dormitoryNo != null">dormitory_no,</if>
            <if test="phone != null and phone != ''">phone,</if>
            <if test="wechatEnterpriseId != null and wechatEnterpriseId != ''">wechat_enterprise_id,</if>
            <if test="flowPositionId != null">flow_position_id,</if>
            <if test="currentLatitude != null">current_latitude,</if>
            <if test="currentLongitude != null">current_longitude,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="studentId != null">#{studentId},</if>
            <if test="studentNum != null">#{studentNum},</if>
            <if test="name != null and name != ''">#{name},</if>
            <if test="gender != null and gender != ''">#{gender},</if>
            <if test="college != null and college != ''">#{college},</if>
            <if test="major != null and major != ''">#{major},</if>
            <if test="dormitoryId != null">#{dormitoryId},</if>
            <if test="dormitoryNo != null">#{dormitoryNo},</if>
            <if test="phone != null and phone != ''">#{phone},</if>
            <if test="wechatEnterpriseId != null and wechatEnterpriseId != ''">#{wechatEnterpriseId},</if>
            <if test="flowPositionId != null">#{flowPositionId},</if>
            <if test="currentLatitude != null">#{currentLatitude},</if>
            <if test="currentLongitude != null">#{currentLongitude},</if>
         </trim>
    </insert>

    <update id="updateStudents" parameterType="Students">
        update students
        <trim prefix="SET" suffixOverrides=",">
            <if test="studentNum != null">student_num = #{studentNum},</if>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="gender != null and gender != ''">gender = #{gender},</if>
            <if test="college != null and college != ''">college = #{college},</if>
            <if test="major != null and major != ''">major = #{major},</if>
            <if test="dormitoryId != null">dormitory_id = #{dormitoryId},</if>
            <if test="dormitoryNo != null">dormitory_no = #{dormitoryNo},</if>
            <if test="phone != null and phone != ''">phone = #{phone},</if>
            <if test="wechatEnterpriseId != null and wechatEnterpriseId != ''">wechat_enterprise_id = #{wechatEnterpriseId},</if>
            <if test="flowPositionId != null">flow_position_id = #{flowPositionId},</if>
            <if test="currentLatitude != null">current_latitude = #{currentLatitude},</if>
            <if test="currentLongitude != null">current_longitude = #{currentLongitude},</if>
        </trim>
        where student_id = #{studentId}
    </update>

    <delete id="deleteStudentsByStudentId" parameterType="Long">
        delete from students where student_id = #{studentId}
    </delete>

    <delete id="deleteStudentsByStudentIds" parameterType="String">
        delete from students where student_id in 
        <foreach item="studentId" collection="array" open="(" separator="," close=")">
            #{studentId}
        </foreach>
    </delete>
</mapper>