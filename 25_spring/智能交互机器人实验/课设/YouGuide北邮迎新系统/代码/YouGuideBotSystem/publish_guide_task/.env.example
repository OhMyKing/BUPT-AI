# Dify Plugin Development Environment Variables
# Copy this file to .env and fill in the values

# Plugin installation method
# Set to "remote" to connect to a Dify instance through the network
INSTALL_METHOD=remote

# Remote Dify instance URL for debugging
# Example: debug.dify.ai:5003
REMOTE_INSTALL_URL=https://example.invalid/install

# Debug key from your Dify instance
# Get this from the plugin management page in Dify
REMOTE_INSTALL_KEY=your_remote_install_key

# Navigation API Configuration (for local testing)
# This is used when testing the plugin locally
NAVIGATION_API_BASE_URL=https://example.invalid/navigation