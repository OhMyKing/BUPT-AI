# Dify Plugin Debug Configuration
# Copy this file to .env and fill in your actual values

# Installation method - set to 'remote' for debugging
INSTALL_METHOD=remote

# Remote debugging host and port
# For Dify SaaS: debug.dify.ai:5003
# For self-hosted: your-dify-instance:5003
REMOTE_INSTALL_URL=https://example.invalid/install

# Debug key from your Dify instance
# Get this from the plugin management page debug button
REMOTE_INSTALL_KEY=your_remote_install_key