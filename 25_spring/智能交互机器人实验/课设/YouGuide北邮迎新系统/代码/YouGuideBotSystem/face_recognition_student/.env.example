# Dify Plugin Debug Configuration
# Copy this file to .env and configure the values

# Installation method (local or remote)
INSTALL_METHOD=remote

# Remote installation URL - Dify plugin-daemon service
# For Dify SaaS: debug.dify.ai:5003
# For self-hosted: your-domain:5003
REMOTE_INSTALL_URL=https://example.invalid/install

# Remote installation key - get this from Dify plugin management page
# Click the debug icon to get your unique key
REMOTE_INSTALL_KEY=your_remote_install_key

# Plugin credentials (for local testing)
# These will be configured in Dify UI when the plugin is installed
FACE_RECOGNITION_URL=https://example.invalid/face-recognition
STUDENT_INFO_URL=https://example.invalid/students